APP_NAME=SentinelAI
APP_ENV=development
DEBUG=True

POSTGRES_USER=sentinel_user
POSTGRES_PASSWORD=sentinel_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinelai_db

LOG_LEVEL=INFO

# Optional. Powers the AI-assisted incident summary on
# GET /incidents/{incident_id}/investigation. Leave unset to use the
# deterministic fallback summary instead -- the endpoint works either way.
# ANTHROPIC_API_KEY=sk-ant-...
# AI_SUMMARY_MODEL=claude-haiku-4-5-20251001
